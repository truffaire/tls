# ── Convex ───────────────────────────────────────────────────
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# ── WorkOS AuthKit ───────────────────────────────────────────
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxx
VITE_WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxx
VITE_WORKOS_REDIRECT_URI=http://127.0.0.1:5173/callback
VITE_WORKOS_DEV_MODE=true

# ── Razorpay (frontend) ───────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx

# ── Razorpay (backend / Convex env) ──────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic (Convex env — never expose to frontend) ────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
